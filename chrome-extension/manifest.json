{
    "manifest_version": 3,
    "name": "AI Job Hunter",
    "version": "1.0.0",
    "description": "Save job postings from LinkedIn, Naukri, and Indeed directly to your AI Job Hunter dashboard.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://*.linkedin.com/*",
        "https://*.naukri.com/*",
        "https://*.indeed.com/*",
        "http://localhost:8000/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.linkedin.com/*",
                "https://*.naukri.com/*",
                "https://*.indeed.com/*"
            ],
            "js": ["content.js"],
            "run_at": "dom_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}